# AshXMusic API – Environment Configuration
# Copy this file to .env and customize as needed.

# Server settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# yt-dlp cookies file (Netscape format) to bypass YouTube bot detection.
# Export cookies from your browser and place the file in the project root,
# then set this path. See README.md for a step-by-step guide.
COOKIES_FILE=cookies.txt

# API base URL – used to build absolute stream/download URLs in search results.
# Set to your deployed URL (e.g. https://ashxmusic.onrender.com) or leave blank
# for relative paths.
BASE_URL=https://ashxmusic.onrender.com

# Admin token for the /cookies/upload endpoint (set a strong random secret).
# Leave blank to disable the upload endpoint.
COOKIES_ADMIN_TOKEN=
